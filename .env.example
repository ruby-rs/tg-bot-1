# --- Telegram bot ---
BOT_TOKEN=123456:your-telegram-bot-token

# --- Web interface ---
# Пароль для входа на сайт (один пользователь).
WEB_PASSWORD=change-this-password
# Секрет для подписи сессионной куки. Сгенерируй: python -c "import secrets; print(secrets.token_hex(32))"
WEB_SECRET_KEY=change-this-to-a-long-random-hex
# Порт, на котором веб будет доступен на сервере.
WEB_PORT=8000
# Чтобы веб и бот вели ОДНОГО пользователя, укажи сюда свой Telegram id
# (узнать: напиши @userinfobot). 0 = отдельный веб-пользователь.
WEB_USER_TG_ID=0
WEB_USER_NAME=Веб

# --- Общее ---
# Локальный запуск без Docker. В docker-compose путь задаётся автоматически.
DB_PATH=life_tracker.db
